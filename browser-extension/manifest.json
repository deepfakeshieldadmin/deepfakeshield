{
  "manifest_version": 3,
  "name": "DeepFake Shield",
  "version": "1.0.0",
  "description": "Right-click any image to check if it's a deepfake. Powered by DeepFake Shield AI.",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  }
}